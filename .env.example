# SharpQA Sales Agent — Configuration
# Copy this to .env and adjust as needed

# Paths (relative to project root)
SQLITE_DB_PATH=data/SharpQA.db
CHROMA_PERSIST_DIR=data/chroma
LOG_DIR=data/logs
SCREENSHOTS_DIR=data/screenshots
EXPORTS_DIR=data/exports

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3.1:8b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=120

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Playwright
PLAYWRIGHT_HEADLESS=true

# Rate limits (per day)
MAX_CONCURRENT_ANALYZES=2
DAILY_SOURCE_LIMIT_YC=50
DAILY_SOURCE_LIMIT_WELLFOUND=30
DAILY_SOURCE_LIMIT_PRODUCTHUNT=50
DAILY_SOURCE_LIMIT_GITHUB=50

# Operator info (used in outreach emails)
OPERATOR_NAME=Arslan
OPERATOR_COMPANY=SharpQA
OPERATOR_BOOKING_LINK=https://cal.com/your-link

# Optional API tokens
GITHUB_PERSONAL_TOKEN=
PRODUCT_HUNT_TOKEN=

# Dashboard
DASHBOARD_PASSWORD=
DASHBOARD_PORT=8501
API_PORT=8000

# Scheduler
NIGHTLY_SOURCE_CRON_HOUR=2
NIGHTLY_SOURCE_CRON_MINUTE=0

# Prioritizer
MIN_PRIORITY_SCORE_FOR_DRAFTING=0.6
